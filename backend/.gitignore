# Carbon Credit Backend — Blockchain-Based Carbon Credit Verification System
# Gitignore for Python + Node.js (Hardhat) project

# ── Python ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
venv/
.venv/
env/

# ── Environment ────────────────────────────────
.env
.env.local
.env.production

# ── Firebase ───────────────────────────────────
firebase-credentials.json

# ── MQTT TLS Certs ─────────────────────────────
mosquitto/certs/
*.key
*.csr
*.srl

# ── Node.js / Hardhat ─────────────────────────
node_modules/
hardhat/artifacts/
hardhat/cache/
hardhat/typechain-types/

# ── IDE ────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ─────────────────────────────────────────
.DS_Store
Thumbs.db
