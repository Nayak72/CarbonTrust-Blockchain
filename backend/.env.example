# FastAPI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-secret-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# MQTT
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=8883
MQTT_USERNAME=backend_user
MQTT_PASSWORD=your-mqtt-password
MQTT_TLS_ENABLED=true
MQTT_CA_CERT_PATH=./mosquitto/certs/ca.crt

# Pinata IPFS
PINATA_API_KEY=your-pinata-api-key
PINATA_SECRET_API_KEY=your-pinata-secret
PINATA_GATEWAY=https://gateway.pinata.cloud

# Polygon Blockchain
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
POLYGON_CHAIN_ID=80002
CONTRACT_ADDRESS=0xYourDeployedContractAddress
DEPLOYER_PRIVATE_KEY=your-wallet-private-key

# Firebase Admin SDK
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Emission Calculation
AMBIENT_CO2_PPM=400
DEFAULT_FLOW_RATE_M3_S=0.5
CREDIT_CALCULATION_WINDOW_HOURS=24
ANOMALY_ZSCORE_THRESHOLD=3.0
ANOMALY_FROZEN_COUNT_THRESHOLD=5

# Polygonscan (for contract verification)
POLYGONSCAN_API_KEY=your-polygonscan-api-key
